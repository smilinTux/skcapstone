{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{SKMEMORY_HOOKS_DIR}}/pre-compact-save.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{SKMEMORY_HOOKS_DIR}}/session-end-save.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "{{SKMEMORY_HOOKS_DIR}}/session-start-ritual.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{SKMEMORY_HOOKS_DIR}}/post-compact-reinject.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "{{SKMEMORY_HOOKS_DIR}}/post-compact-reinject.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{SKMEMORY_HOOKS_DIR}}/stop-checkpoint.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "sonnet"
}
