[Unit]
Description=SKCapstone Housekeeping — prune stale inbox/outbox envelopes, derived junk, and legacy comms
Documentation=https://github.com/smilinTux/skcapstone
After=network-online.target

[Service]
Type=oneshot
ExecStart=skcapstone housekeeping
Nice=15

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.skcapstone %h/.skcomms
PrivateTmp=true

Environment=PYTHONUNBUFFERED=1
